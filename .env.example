# =============================================================================
# Google Pay Configuration
# =============================================================================
# Get from Google Pay & Wallet Console: https://pay.google.com/business/console
GOOGLE_PAY_MERCHANT_ID=your-google-pay-merchant-id
GOOGLE_PAY_MERCHANT_NAME=Your Business Name
GOOGLE_PAY_ENVIRONMENT=TEST

# =============================================================================
# MPGS Gateway Configuration
# =============================================================================
# Get from MPGS Merchant Admin: https://your-region.gateway.mastercard.com/ma
# Merchant ID: your MPGS merchant profile ID (e.g., TESTMERCHANT123)
# API Password: generated in MPGS admin under "Admin > API Password"
MPGS_GATEWAY=mpgs
MPGS_GATEWAY_MERCHANT_ID=your-mpgs-merchant-id
MPGS_API_PASSWORD=your-mpgs-api-password
MPGS_API_VERSION=73
MPGS_BASE_URL=https://test-gateway.mastercard.com

# =============================================================================
# Server
# =============================================================================
PORT=3000
# For local dev use http://localhost:3000
# For Vercel deployment use your actual domain
BASE_URL=https://your-app.vercel.app
